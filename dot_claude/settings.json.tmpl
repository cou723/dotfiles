{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "WebSearch",
      "mcp__brave-search__brave_web_search"
    ]
  },
  "mcpServers": {
    "brave-search": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-brave-search"],
      "env": {
        "BRAVE_API_KEY": "{{ env "BRAVE_API_KEY" | default "" }}"
      }
    }
  },
  "model": "sonnet",
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -ExecutionPolicy RemoteSigned -Command \"New-BurntToastNotification -Text 'WSL ClaudeCode', 'Claude Codeが入力を待っています...'\""
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -ExecutionPolicy RemoteSigned -Command \"New-BurntToastNotification -Text 'WSL ClaudeCode', 'Claude Codeが入力を待っています...'\""
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "moonbit-practice@moonbit-practice": true,
    "code-review@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "plugin-dev@claude-plugins-official": true,
    "mcp-server-dev@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "effect-ts": {
      "source": {
        "source": "github",
        "repo": "andrueandersoncs/claude-skill-effect-ts"
      }
    }
  },
  "tui": "fullscreen",
  "agentPushNotifEnabled": true
}
