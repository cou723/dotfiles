{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "ANTHROPIC_AUTH_TOKEN": "e22a0063346d4dc0a9acd2eb27581c36.BJunQzpkymmp2OYz",
    "ANTHROPIC_BASE_URL": "https://api.z.ai/api/anthropic",
    "API_TIMEOUT_MS": "3000000",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "glm-4.5-air",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "glm-4.7",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "glm-4.7",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1"
  },
  "permissions": {
    "allow": [
      "WebSearch"
    ],
    "additionalDirectories": [
      "~/.claude/skills"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            {{ if (.chezmoi.kernel.osrelease | lower | contains "microsoft") }}
            "command": "powershell.exe -ExecutionPolicy RemoteSigned -Command \"New-BurntToastNotification -Text 'WSL ClaudeCode', 'Claude Codeが入力を待っています...'\""
            {{ else }}
            "command": "paplay /usr/share/sounds/freedesktop/stereo/bell.oga"
            {{ end }}
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            {{ if (.chezmoi.kernel.osrelease | lower | contains "microsoft") }}
            "command": "powershell.exe -ExecutionPolicy RemoteSigned -Command \"New-BurntToastNotification -Text 'WSL ClaudeCode', 'Claude Codeが入力を待っています...'\""
            {{ else }}
            "command": "paplay /usr/share/sounds/freedesktop/stereo/bell.oga"
            {{ end }}
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "moonbit-practice@moonbit-practice": true,
    "github@claude-plugins-official": true
  }
}
